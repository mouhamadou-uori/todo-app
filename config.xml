<?xml version='1.0' encoding='utf-8'?>
<widget id="com.mwndour.todoswipe" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Todo</name>
    <description>Liste de tâches mobile avec gestes swipe — Cordova + jQuery Mobile.</description>
    <author email="mouhamadou.ndour@myriadgroup.com">Mouhamadou Wally Ndour</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <preference name="Orientation" value="portrait" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackgroundColor" value="#ff0e0f12" />
    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="36" />
    </platform>
</widget>
